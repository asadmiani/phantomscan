def warning_panel():
    return Panel(
        "‚ö† Only use for ethical testing",
        title="Warning"
    )


def lock_panel(frame):

    return Panel(
        frame,
        title="Security Core",
    )


def scanner_panel():

    text = """
PhantomScan Scanner Output

Waiting for target...
"""

    return Panel(text, title="Scanner")


def tools_panel():

    tools = """
Running Tools

nmap
crawler
sql scanner
xss scanner
api scanner
"""

    return Panel(tools, title="Tools")
lock_frames = [
"""
       access
   secure   protect

