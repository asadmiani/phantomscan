import itertools
from rich.layout import Layout
from rich.panel import Panel
from rich.live import Live
import psutil
import time


def generate_layout():

    layout = Layout()

    # Two rows
    layout.split_column(
        Layout(name="row1", size=8),
        Layout(name="row2")
    )

    # Row 1 columns
    layout["row1"].split_row(
        Layout(name="ram", ratio=1),
        Layout(name="cpu", ratio=1),
        Layout(name="logo", ratio=3),
        Layout(name="warning", ratio=1),
    )

    # Row 2 columns
    layout["row2"].split_row(
        Layout(name="lock", ratio=1),
        Layout(name="scanner", ratio=2),
        Layout(name="tools", ratio=1),
    )

    return layout

   def create_bar(percentage, length=20):

       filled = int((percentage / 100) * length)
       empty = length - filled

       bar = "‚Ėą" * filled + "-" * empty

       return f"[{bar}] {percentage}%"
   def ram_panel():
       ram = psutil.virtual_memory().percent
       return Panel(f"RAM Usage\n\n{ram}%", title="RAM")


   def cpu_panel():
       cpu = psutil.cpu_percent()
       return Panel(f"CPU Usage\n\n{cpu}%", title="CPU")


